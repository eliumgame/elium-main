# Copy to ../.env (repo root) before `docker compose up -d --build`.

# Your domain for automatic HTTPS. Use ":80" for a local/no-TLS test.
SITE_ADDRESS=drive.example.com

# Access-token signing secret. Generate a strong one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
TOKEN_SECRET=CHANGE_ME_long_random_secret

# Postgres password (also used in the api DATABASE_URL via compose).
POSTGRES_PASSWORD=CHANGE_ME_db_password

# Allowed browser origins for the API (comma-separated). Usually your site URL.
CORS_ORIGINS=https://drive.example.com

# --- Storage (optional) ----------------------------------------------------
# Default is "fs" (the blobs docker volume). To use S3/MinIO instead, set:
#   STORAGE_DRIVER=s3
# and start MinIO with:  docker compose --profile s3 up -d --build
# (then create the bucket once via the MinIO console at :9001).
STORAGE_DRIVER=fs
S3_ACCESS_KEY=elium
S3_SECRET_KEY=CHANGE_ME_minio_secret
S3_BUCKET=elium-blobs
