# Edge reverse proxy for Elium Drive Entreprise.
# Set SITE_ADDRESS to your domain (e.g. drive.example.com) in prod to get
# automatic HTTPS. Defaults to :80 locally.

# Global options. ACME_EMAIL is optional: when unset/empty, Caddy just skips
# registering an ACME account email (no error) and still issues certs fine.
{
	email {$ACME_EMAIL}
}

{$SITE_ADDRESS::80} {
	encode zstd gzip

	# API + WebSocket collaboration relay -> the api service.
	handle /api/* {
		reverse_proxy api:8787
	}

	# Everything else -> the static web app (SPA).
	handle {
		reverse_proxy web:80
	}
}
