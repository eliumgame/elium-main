# --- Elium Drive Entreprise — server configuration -------------------------
# Copy to .env for local dev. In production these are injected by docker-compose.

# HTTP
PORT=8787
HOST=0.0.0.0
# Comma-separated list of allowed web origins (the web-studio app).
CORS_ORIGINS=http://localhost:3100,http://localhost:5173

# Postgres
DATABASE_URL=postgres://elium:elium@localhost:5432/elium

# Access-token signing secret (HMAC-SHA256). MUST be long & random in prod.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
TOKEN_SECRET=dev-only-change-me-please-32bytes-minimum-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Blob storage: "fs" (local volume) or "s3" (MinIO / S3-compatible)
STORAGE_DRIVER=fs
STORAGE_FS_ROOT=./data/blobs
# S3 / MinIO (used when STORAGE_DRIVER=s3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=elium-blobs
S3_ACCESS_KEY=elium
S3_SECRET_KEY=elium-secret
S3_FORCE_PATH_STYLE=true

# Limits
MAX_BLOB_BYTES=2147483648
MAX_JSON_BYTES=1048576
