# Ne pas exécuter les scripts d'installation des dépendances.
# Raison : le postinstall d'esbuild (node install.js) fait échouer `npm ci` sur les
# runners CI en npm 10 (node 20), alors que npm 11 (local) les bloque déjà par défaut.
# Le binaire esbuild est fourni par ses dépendances optionnelles @esbuild/<plateforme>,
# donc le build fonctionne sans ce script. C'est aussi plus sûr (pas de script arbitraire).
ignore-scripts=true

# IMPORTANT — régénérer package-lock.json avec npm 10 (la CI tourne sur Node 22 → npm 10).
# npm 11 (Node ≥ 24) déduplique les dépendances optionnelles imbriquées (ex.
# esbuild@0.28.1 sous tsx) et les OMET du lock ; le `npm ci` de npm 10 les exige et
# échoue alors avec « Missing: esbuild@0.28.1 from lock file ». Si vous êtes sur npm 11,
# régénérez le lock via :  npx npm@10 install --package-lock-only
